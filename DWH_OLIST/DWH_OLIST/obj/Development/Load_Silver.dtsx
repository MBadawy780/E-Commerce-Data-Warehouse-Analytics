                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset">[bronze].[olist_orders]</property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
    CAST(order_id AS NVARCHAR(50))                    AS order_id,
    CAST(customer_id AS NVARCHAR(50))                 AS customer_id,
    CAST(order_status AS NVARCHAR(50))                AS order_status,
    TRY_CAST(order_purchase_timestamp AS DATETIME)    AS purchase_at,
    TRY_CAST(order_approved_at AS DATETIME)           AS approved_at,
    TRY_CAST(order_delivered_carrier_date AS DATETIME)   AS delivered_carrier_at,
    TRY_CAST(order_delivered_customer_date AS DATETIME)  AS delivered_customer_at,
    TRY_CAST(order_estimated_delivery_date AS DATETIME)  AS estimated_delivery_at,
    DATEDIFF(DAY,
        TRY_CAST(order_purchase_timestamp AS DATETIME),
        TRY_CAST(order_delivered_customer_date AS DATETIME))  AS delivery_time_days,
    DATEDIFF(DAY,
        TRY_CAST(order_estimated_delivery_date AS DATETIME),
        TRY_CAST(order_delivered_customer_date AS DATETIME))  AS delay_vs_estimated,
    DATEDIFF(HOUR,
        TRY_CAST(order_purchase_timestamp AS DATETIME),
        TRY_CAST(order_approved_at AS DATETIME))              AS approval_time_hours,
    CASE
        WHEN TRY_CAST(order_delivered_customer_date AS DATETIME)
             &lt;= TRY_CAST(order_estimated_delivery_date AS DATETIME)
        THEN 'On Time' ELSE 'Late'
    END                                               AS delivery_performance_status,
    Ingestion_DateTime                                AS created_at,
    GETDATE()                                         AS updated_at
FROM bronze.olist_orders</property>
