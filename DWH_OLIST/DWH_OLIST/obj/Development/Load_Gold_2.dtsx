                <component
                  refId="Package\dim_date\dim_date\OLE DB Source"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="OLE DB Source"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 
    -- date_id (PK)
    CAST(CONVERT(VARCHAR(8), DATEADD(DAY, number, '2015-01-01'), 112) AS INT) AS date_id,
    
    -- full_date
    CAST(DATEADD(DAY, number, '2015-01-01') AS DATE) AS full_date,
    
    -- year
    YEAR(DATEADD(DAY, number, '2015-01-01')) AS [year],
    
    -- quarter
    DATEPART(QUARTER, DATEADD(DAY, number, '2015-01-01')) AS [quarter],
    
    -- month
    MONTH(DATEADD(DAY, number, '2015-01-01')) AS [month],
    
    -- day
    DAY(DATEADD(DAY, number, '2015-01-01')) AS [day],
    
    -- month_name (Fixed CAST syntax)
    CAST(DATENAME(MONTH, DATEADD(DAY, number, '2015-01-01')) AS NVARCHAR(20)) AS month_name,
    
    -- week_of_year
    DATEPART(WEEK, DATEADD(DAY, number, '2015-01-01')) AS week_of_year,
    
    -- day_name (Fixed CAST syntax)
    CAST(DATENAME(WEEKDAY, DATEADD(DAY, number, '2015-01-01')) AS NVARCHAR(20)) AS day_name,
    
    -- is_weekend
    CASE 
        WHEN DATEPART(WEEKDAY, DATEADD(DAY, number, '2015-01-01')) IN (1, 7) THEN 1 
        ELSE 0 
    END AS is_weekend

FROM 
    master..spt_values
WHERE 
    type = 'P' 
    AND number &lt;= DATEDIFF(DAY, '2015-01-01', '2020-12-31')
ORDER BY 
    date_id;</property>
